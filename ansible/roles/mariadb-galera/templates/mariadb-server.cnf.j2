# MariaDB Server Configuration para Debian Linux
# Generado por Ansible

[mysqld]
datadir=/var/lib/mysql
socket=/run/mysqld/mysqld.sock
user=mysql
pid-file=/run/mysqld/mysqld.pid

# Desactivar SSL (no requerido en red interna)
skip_ssl

# Optimizaciones para poca RAM
key_buffer_size=16M
max_allowed_packet=16M
thread_stack=192K
thread_cache_size=8
max_connections=50

[mysqld_safe]
log-error=/var/log/mysql/error.log
pid-file=/run/mysqld/mysqld.pid
