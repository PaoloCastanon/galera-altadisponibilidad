    },
    "ssh_connection_examples": {
      "value": "# Conectar a balanceadores:\nssh debian@192.168.122.11  # lb1\nssh debian@192.168.122.12  # lb2\n\n# Conectar a nodos de BD:\nssh debian@192.168.122.21  # db1\nssh debian@192.168.122.22  # db2\nssh debian@192.168.122.23  # db3\n\n# Conectar a MySQL via VIP:\nmysql -h 192.168.122.10 -P 3306 -u haproxy_check -p\n",
      "type": "string"
    },
    "vip_address": {
      "value": "192.168.122.10",
      "type": "string"
    }
  },
  "resources": [
    {
      "mode": "managed",
      "type": "libvirt_cloudinit_disk",
      "name": "vm_cloudinit",
      "provider": "provider[\"registry.terraform.io/dmacvicar/libvirt\"]",
      "instances": [
        {
          "index_key": "db1",
          "schema_version": 0,
          "attributes": {
            "id": "/var/lib/libvirt/images/db1-cloudinit.iso;474f28eb-5474-4f39-8a9e-3f4f61caf546",
            "meta_data": "",
            "name": "db1-cloudinit.iso",
            "network_config": "version: 2\nethernets:\n  ens3:\n    dhcp4: false\n    addresses:\n      - 192.168.122.21/24\n    gateway4: 192.168.122.1\n    nameservers:\n      addresses:\n        - 192.168.122.1\n        - 8.8.8.8\n",
            "pool": "default",
            "user_data": "#cloud-config\nhostname: db1\nfqdn: db1.local\nmanage_etc_hosts: true\n\nusers:\n  - name: debian\n    sudo: ALL=(ALL) NOPASSWD:ALL\n    shell: /bin/bash\n    ssh_authorized_keys:\n      - ssh-rsa  juanc@JC\n\n\nssh_pwauth: false\ndisable_root: false\n\npackages:\n  - python3\n  - sudo\n  - openssh-server\n  - qemu-guest-agent\n\nruncmd:\n  - systemctl enable qemu-guest-agent\n  - systemctl start qemu-guest-agent\n  - sed -i 's/^#PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config\n  - systemctl restart ssh\n\nfinal_message: \"VM db1 lista en $UPTIME segundos\"\n"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "bnVsbA=="
        },
        {
          "index_key": "db2",
